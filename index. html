<title>Velugeetha Books | వెలుగీత పుస్తకాలు</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Tiro+Tamil:ital@0;1&family=Noto+Sans+Telugu:wght@400;600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
<style>
:root {
  --gold: #c8860a;
  --deep-gold: #a06800;
  --saffron: #e8940a;
  --cream: #fdf6e3;
  --dark: #1a1008;
  --brown: #3d1f00;
  --warm-gray: #7a6a55;
  --accent-red: #b5280a;
  --light-gold: #f5dfa0;
  --bg: #fef9f0;
  --card-bg: #fffdf5;
  --border: #e8d5a0;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  background:var(--bg);
  color:var(--dark);
  font-family:'Lato',sans-serif;
  line-height:1.7;
}

/* HERO */
.hero{
  background: linear-gradient(135deg, #1a0a00 0%, #3d1500 40%, #6b2a00 100%);
  color:#fff;
  padding:70px 20px 60px;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.hero::before{
  content:'';
  position:absolute;inset:0;
  background: radial-gradient(ellipse at 50% 0%, rgba(200,134,10,0.3) 0%, transparent 70%);
}
.hero-lamp{font-size:3.5rem;margin-bottom:12px;display:block;animation:glow 3s ease-in-out infinite alternate;}
@keyframes glow{from{filter:drop-shadow(0 0 8px #ffaa00);} to{filter:drop-shadow(0 0 24px #ffcc44);}}
.hero h1{
  font-family:'Playfair Display',serif;
  font-size:clamp(2.2rem,5vw,3.8rem);
  font-weight:900;
  letter-spacing:-0.5px;
  color:#fde68a;
  position:relative;
}
.hero-sub{
  font-family:'Tiro Tamil',serif;
  font-size:1.3rem;
  color:#fcd97a;
  margin-top:6px;
  position:relative;
}
.lang-tags{
  display:flex;flex-wrap:wrap;justify-content:center;gap:8px;
  margin-top:24px;position:relative;
}
.lang-tag{
  background:rgba(255,255,255,0.12);
  border:1px solid rgba(200,134,10,0.5);
  color:#fde68a;
  padding:5px 16px;
  border-radius:20px;
  font-size:0.85rem;
  letter-spacing:0.5px;
}
.badge{
  display:inline-block;
  background:#c8860a;
  color:#fff;
  padding:4px 14px;
  border-radius:20px;
  font-size:0.8rem;
  font-weight:700;
  letter-spacing:1px;
  margin-top:18px;
  position:relative;
}

/* NAV */
nav{
  background:var(--brown);
  padding:0 20px;
  display:flex;
  justify-content:center;
  gap:4px;
  flex-wrap:wrap;
  position:sticky;top:0;z-index:100;
  box-shadow:0 2px 12px rgba(0,0,0,0.3);
}
nav a{
  color:#fde68a;
  text-decoration:none;
  padding:14px 16px;
  font-size:0.88rem;
  font-weight:700;
  letter-spacing:0.5px;
  border-bottom:3px solid transparent;
  transition:border-color 0.2s,color 0.2s;
}
nav a:hover{border-bottom-color:var(--gold);color:#fff;}

/* SECTIONS */
section{padding:60px 20px;}
.section-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(1.8rem,4vw,2.6rem);
  color:var(--brown);
  text-align:center;
  margin-bottom:8px;
}
.section-sub{
  text-align:center;
  color:var(--warm-gray);
  margin-bottom:40px;
  font-size:1rem;
}
.divider{
  width:80px;height:3px;
  background:linear-gradient(90deg,var(--gold),var(--saffron));
  margin:12px auto 40px;
  border-radius:2px;
}

/* BOOK CARDS */
.books-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:28px;
  max-width:1100px;
  margin:0 auto;
}
.book-card{
  background:var(--card-bg);
  border:1px solid var(--border);
  border-radius:16px;
  overflow:hidden;
  box-shadow:0 4px 20px rgba(100,60,0,0.08);
  transition:transform 0.3s,box-shadow 0.3s;
}
.book-card:hover{transform:translateY(-6px);box-shadow:0 12px 36px rgba(100,60,0,0.16);}
.book-header{
  padding:22px 22px 16px;
  border-bottom:1px solid var(--border);
  background:linear-gradient(135deg,#fffbee,#fef3cc);
}
.book-icon{font-size:2.2rem;margin-bottom:8px;display:block;}
.book-title{
  font-family:'Playfair Display',serif;
  font-size:1.2rem;
  font-weight:700;
  color:var(--brown);
  margin-bottom:6px;
}
.book-tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:8px;}
.book-tag{
  background:var(--light-gold);
  color:var(--deep-gold);
  padding:2px 10px;
  border-radius:12px;
  font-size:0.73rem;
  font-weight:700;
  letter-spacing:0.5px;
}
.book-body{padding:20px 22px;}
.book-preview-text{
  font-size:0.95rem;
  color:#4a3520;
  line-height:1.75;
  margin-bottom:16px;
}
.tts-bar{
  background:#fef6e4;
  border:1px solid var(--border);
  border-radius:10px;
  padding:12px 14px;
  margin-bottom:16px;
}
.tts-label{font-size:0.75rem;color:var(--warm-gray);margin-bottom:8px;font-weight:700;letter-spacing:0.5px;}
.tts-langs{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px;}
.tts-btn{
  background:#fff;
  border:1.5px solid var(--border);
  color:var(--brown);
  padding:4px 12px;
  border-radius:8px;
  font-size:0.78rem;
  cursor:pointer;
  font-weight:600;
  transition:all 0.2s;
}
.tts-btn:hover,.tts-btn.active{background:var(--gold);border-color:var(--gold);color:#fff;}
.tts-controls{display:flex;gap:8px;align-items:center;}
.play-btn{
  background:linear-gradient(135deg,var(--gold),var(--saffron));
  color:#fff;
  border:none;
  padding:8px 18px;
  border-radius:8px;
  cursor:pointer;
  font-size:0.85rem;
  font-weight:700;
  display:flex;align-items:center;gap:6px;
  transition:opacity 0.2s,transform 0.1s;
}
.play-btn:hover{opacity:0.9;transform:scale(1.02);}
.stop-btn{
  background:#fff;border:1.5px solid var(--border);
  color:var(--warm-gray);padding:8px 14px;
  border-radius:8px;cursor:pointer;font-size:0.85rem;
  transition:all 0.2s;
}
.stop-btn:hover{border-color:var(--accent-red);color:var(--accent-red);}
.tts-status{font-size:0.75rem;color:var(--warm-gray);margin-left:4px;}

.price-row{
  display:flex;align-items:center;justify-content:space-between;
  margin-top:10px;
  padding-top:14px;
  border-top:1px solid var(--border);
}
.price{
  font-family:'Playfair Display',serif;
  font-size:1.4rem;
  font-weight:700;
  color:var(--deep-gold);
}
.buy-btn{
  background:linear-gradient(135deg,var(--accent-red),#8b1a00);
  color:#fff;
  border:none;
  padding:9px 22px;
  border-radius:9px;
  font-weight:700;
  font-size:0.88rem;
  cursor:pointer;
  text-decoration:none;
  display:inline-block;
  transition:opacity 0.2s,transform 0.1s;
  letter-spacing:0.5px;
}
.buy-btn:hover{opacity:0.88;transform:scale(1.03);}

/* PERIYAR SECTION */
#periyar{background:linear-gradient(180deg,#1a0a00 0%,#2d1200 100%);color:#fff;}
#periyar .section-title{color:#fde68a;}
#periyar .section-sub{color:#d4a04a;}
#periyar .divider{background:linear-gradient(90deg,#fde68a,#c8860a);}

.periyar-intro{
  max-width:750px;margin:0 auto 40px;
  text-align:center;
  font-size:1.05rem;
  color:#e8d5a0;
  line-height:1.8;
}
.periyar-quote{
  background:rgba(200,134,10,0.15);
  border-left:4px solid var(--gold);
  padding:16px 20px;
  border-radius:0 10px 10px 0;
  font-style:italic;
  color:#fde68a;
  margin:20px 0;
  font-family:'Playfair Display',serif;
  font-size:1.05rem;
}

.lang-tabs{
  display:flex;flex-wrap:wrap;justify-content:center;gap:8px;
  margin-bottom:30px;
}
.lang-tab{
  background:rgba(255,255,255,0.08);
  border:1.5px solid rgba(200,134,10,0.3);
  color:#fde68a;
  padding:8px 20px;
  border-radius:22px;
  cursor:pointer;
  font-size:0.88rem;
  font-weight:700;
  transition:all 0.2s;
}
.lang-tab:hover,.lang-tab.active{
  background:var(--gold);
  border-color:var(--gold);
  color:#1a0800;
}

.periyar-content{display:none;}
.periyar-content.active{display:block;}
.periyar-card{
  max-width:800px;
  margin:0 auto;
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(200,134,10,0.3);
  border-radius:16px;
  padding:30px;
}
.periyar-card h3{
  font-family:'Playfair Display',serif;
  font-size:1.4rem;
  color:#fde68a;
  margin-bottom:6px;
}
.periyar-card .sub{color:#c8a04a;font-size:0.9rem;margin-bottom:20px;}
.periyar-card p{
  color:#e8d5b0;
  margin-bottom:14px;
  line-height:1.85;
  font-size:0.97rem;
}
.periyar-tts{
  margin-top:20px;
  display:flex;gap:10px;flex-wrap:wrap;align-items:center;
}
.periyar-play{
  background:linear-gradient(135deg,var(--gold),var(--saffron));
  color:#1a0800;
  border:none;padding:9px 22px;
  border-radius:9px;cursor:pointer;
  font-weight:700;font-size:0.88rem;
  display:flex;align-items:center;gap:6px;
}
.periyar-stop{
  background:transparent;
  border:1.5px solid rgba(200,134,10,0.5);
  color:#fde68a;padding:9px 16px;
  border-radius:9px;cursor:pointer;
  font-size:0.88rem;
}

/* BUNDLE */
#bundle{background:linear-gradient(135deg,#3d1500,#6b2a00);}
#bundle .section-title{color:#fde68a;}
#bundle .divider{background:linear-gradient(90deg,#fde68a,#c8860a);}
.bundle-card{
  max-width:600px;margin:0 auto;
  background:rgba(255,255,255,0.08);
  border:2px solid var(--gold);
  border-radius:20px;
  padding:36px;
  text-align:center;
  color:#fff;
}
.bundle-card h3{
  font-family:'Playfair Display',serif;
  font-size:1.8rem;color:#fde68a;margin-bottom:8px;
}
.bundle-price{
  font-family:'Playfair Display',serif;
  font-size:3rem;color:#fde68a;font-weight:900;margin:16px 0 8px;
}
.bundle-sub{color:#d4a04a;margin-bottom:24px;}
.bundle-buy{
  background:linear-gradient(135deg,#c8860a,#e8940a);
  color:#1a0800;border:none;
  padding:14px 40px;border-radius:12px;
  font-size:1rem;font-weight:900;
  cursor:pointer;text-decoration:none;
  display:inline-block;letter-spacing:1px;
  transition:transform 0.2s,opacity 0.2s;
}
.bundle-buy:hover{transform:scale(1.04);opacity:0.92;}

/* FOOTER */
footer{
  background:var(--dark);
  color:#9a8060;
  text-align:center;
  padding:30px 20px;
  font-size:0.88rem;
}
footer span{color:var(--gold);}

/* ACCESSIBILITY */
.access-bar{
  background:var(--brown);
  color:#fde68a;
  padding:8px 20px;
  display:flex;justify-content:flex-end;gap:10px;align-items:center;
  font-size:0.8rem;
}
.access-bar button{
  background:rgba(255,255,255,0.1);
  border:1px solid rgba(200,134,10,0.4);
  color:#fde68a;padding:3px 10px;
  border-radius:6px;cursor:pointer;font-size:0.8rem;
}
.access-bar button:hover{background:var(--gold);color:#fff;}

/* READING INDICATOR */
.reading-dot{
  display:inline-block;
  width:8px;height:8px;
  background:#22c55e;
  border-radius:50%;
  animation:pulse 1.2s ease-in-out infinite;
  margin-right:4px;
}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(0.7);}}

/* RESPONSIVE */
@media(max-width:600px){
  .books-grid{grid-template-columns:1fr;}
  .price-row{flex-direction:column;gap:12px;align-items:flex-start;}
}
</style>
</head>
