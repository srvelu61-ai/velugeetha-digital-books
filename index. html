function speakBook(bookId){
  stopSpeech();
  const lang = bookLangs[bookId];
  const text = getBookText(bookId, lang);
  const status = document.getElementById(`status-${bookId}`);
  speak(text, lang, status);
}

function speakPeriyar(lang, sectionId){
  stopSpeech();
  const section = document.getElementById(sectionId);
  const paras = section.querySelectorAll('p');
  let text = '';
  paras.forEach(p => text += p.innerText + ' ');
  const status = document.getElementById('status-periyar');
  speak(text, lang, status);
}

function speak(text, lang, statusEl){
  if(!('speechSynthesis' in window)){
    if(statusEl) statusEl.innerHTML = '⚠️ Not supported in this browser';
    return;
  }
  const utter = new SpeechSynthesisUtterance(text);
  utter.lang = lang;
  utter.rate = 0.92;
  utter.pitch = 1;
  if(statusEl){
    statusEl.innerHTML = '<span class="reading-dot"></span> Reading...';
    utter.onend = () => statusEl.innerHTML = '✅ Done';
    utter.onerror = () => statusEl.innerHTML = '⚠️ Error';
  }
  window.speechSynthesis.speak(utter);
}

function stopSpeech(){
  if('speechSynthesis' in window) window.speechSynthesis.cancel();
  document.querySelectorAll('.tts-status').forEach(s=>s.innerHTML='');
}

// ===== PERIYAR TABS =====
function showPeriyar(lang){
  document.querySelectorAll('.periyar-content').forEach(c=>c.classList.remove('active'));
  document.querySelectorAll('.lang-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('periyar-'+lang).classList.add('active');
  event.target.classList.add('active');
  stopSpeech();
}

// ===== ACCESSIBILITY =====
let fontSize = 16;
function changeFontSize(dir){
  fontSize = Math.min(22, Math.max(12, fontSize + dir*2));
  document.body.style.fontSize = fontSize+'px';
}
let highContrast = false;
function toggleContrast(){
  highContrast = !highContrast;
  if(highContrast){
    document.documentElement.style.setProperty('--bg','#000');
    document.documentElement.style.setProperty('--card-bg','#111');
    document.documentElement.style.setProperty('--dark','#fff');
    document.documentElement.style.setProperty('--border','#666');
    document.body.style.background='#000';
  } else {
    document.documentElement.style.setProperty('--bg','#fef9f0');
    document.documentElement.style.setProperty('--card-bg','#fffdf5');
    document.documentElement.style.setProperty('--dark','#1a1008');
    document.documentElement.style.setProperty('--border','#e8d5a0');
    document.body.style.background='#fef9f0';
  }
}
